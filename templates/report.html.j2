<!DOCTYPE html>
<html>
<head>
    <title>Android Forensic Report</title>

    <style>

        body{
            font-family:Arial;
            margin:40px;
            background:#f5f5f5;
        }

        .card{
            background:white;
            padding:20px;
            margin-bottom:20px;
            border-radius:10px;
            box-shadow:0 2px 6px rgba(0,0,0,0.1);
        }

        h1{
            color:#1e3a8a;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        th,td{
            border:1px solid #ccc;
            padding:10px;
            text-align:left;
        }

        th{
            background:#e2e8f0;
        }

    </style>
</head>

<body>

<div class="card">

<h1>Android Forensic Acquisition Report</h1>

<p><b>Case ID:</b> {{ case_id }}</p>
<p><b>Investigator:</b> {{ investigator }}</p>

</div>

<div class="card">

<h2>Device Information</h2>

<table>

<tr>
<th>Field</th>
<th>Value</th>
</tr>

<tr>
<td>Model</td>
<td>{{ device.model }}</td>
</tr>

<tr>
<td>Manufacturer</td>
<td>{{ device.manufacturer }}</td>
</tr>

<tr>
<td>Android Version</td>
<td>{{ device.android_version }}</td>
</tr>

<tr>
<td>Serial</td>
<td>{{ device.serial }}</td>
</tr>

<tr>
<td>Brand</td>
<td>{{ device.brand }}</td>
</tr>

</table>

</div>

<div class="card">

<h2>Artefact Summary</h2>

<table>

<tr>
<th>Artefact</th>
<th>Count</th>
</tr>

<tr>
<td>Installed Apps</td>
<td>{{ app_count }}</td>
</tr>

<tr>
<td>Media Entries</td>
<td>{{ media_count }}</td>
</tr>

</table>

</div>

<div class="card">

<h2>SHA-256 Manifest</h2>

<table>

<tr>
<th>File</th>
<th>SHA-256</th>
</tr>

{% for file, hash in manifest.items() %}
<tr>
<td>{{ file }}</td>
<td>{{ hash }}</td>
</tr>
{% endfor %}

</table>

</div>

</body>
</html>