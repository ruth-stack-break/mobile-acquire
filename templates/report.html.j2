<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Android Forensic Acquisition Report - Case {{ case_id }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0b0f19;
            --bg-secondary: #161f30;
            --bg-card: rgba(22, 31, 48, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --accent-blue: #3b82f6;
            --accent-teal: #10b981;
            --accent-purple: #8b5cf6;
            --accent-red: #ef4444;
            --accent-glow: rgba(59, 130, 246, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            padding: 40px 20px;
            background-image: 
                radial-gradient(at 0% 0%, rgba(59, 130, 246, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.1) 0px, transparent 50%);
            background-attachment: fixed;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Header / Hero Section */
        header {
            background: linear-gradient(135deg, rgba(22, 31, 48, 0.9) 0%, rgba(11, 15, 25, 0.9) 100%);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple), var(--accent-teal));
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 20px;
        }

        .header-title h1 {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(90deg, #fff, #9ca3af);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            background: rgba(59, 130, 246, 0.1);
            color: var(--accent-blue);
            border: 1px solid rgba(59, 130, 246, 0.2);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--accent-teal);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .case-meta {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 30px;
            padding-top: 25px;
            border-top: 1px solid var(--border-color);
        }

        .meta-item {
            display: flex;
            flex-direction: column;
        }

        .meta-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            margin-bottom: 4px;
        }

        .meta-value {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .meta-value.code {
            font-family: 'JetBrains Mono', monospace;
            color: var(--accent-teal);
        }

        /* Summary Badges Grid */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .summary-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            backdrop-filter: blur(8px);
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .summary-card:hover {
            transform: translateY(-5px);
            border-color: rgba(59, 130, 246, 0.3);
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.1);
        }

        .summary-count {
            font-size: 2.2rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 4px;
        }

        .summary-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Main Content Layout */
        .layout-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(8px);
            margin-bottom: 30px;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
        }

        .card-title {
            font-size: 1.4rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-title::before {
            content: '';
            display: inline-block;
            width: 8px;
            height: 18px;
            background: var(--accent-blue);
            border-radius: 4px;
        }

        /* Device Info Grid */
        .device-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .device-info-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .device-info-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .device-info-val {
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.95rem;
        }

        /* Tables styling */
        .table-wrapper {
            overflow-x: auto;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.9rem;
        }

        th {
            background: rgba(255, 255, 255, 0.03);
            color: #fff;
            font-weight: 600;
            padding: 14px 18px;
            border-bottom: 1px solid var(--border-color);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        td {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-primary);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.01);
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
        }

        .hash-val {
            font-family: 'JetBrains Mono', monospace;
            color: var(--accent-teal);
            font-size: 0.82rem;
            word-break: break-all;
        }

        .tab-btn {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .tab-btn.active, .tab-btn:hover {
            background: var(--accent-blue);
            color: #fff;
            border-color: var(--accent-blue);
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.3);
        }

        .tabs-header {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Footer */
        footer {
            margin-top: 50px;
            border-top: 1px solid var(--border-color);
            padding-top: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .footer-logo {
            font-weight: 800;
            color: #fff;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .footer-logo::before {
            content: '⚡';
        }

        .sign-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
        }

        .sign-line {
            border-bottom: 1px solid var(--text-secondary);
            height: 40px;
            margin-bottom: 5px;
        }

        .sign-title {
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-transform: uppercase;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Hero Case Header -->
        <header>
            <div class="header-content">
                <div class="header-title">
                    <span class="badge badge-success">Acquisition Confirmed & Signed</span>
                    <h1 style="margin-top: 10px;">Android Forensic Acquisition Report</h1>
                    <p style="color: var(--text-secondary);">Automated Forensically Sound Image Acquisition</p>
                </div>
                <div>
                    <span class="badge" style="font-family: 'JetBrains Mono', monospace;">Tool v1.0.0</span>
                </div>
            </div>
            
            <div class="case-meta">
                <div class="meta-item">
                    <span class="meta-label">Case Identifier</span>
                    <span class="meta-value code">{{ case_id }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Lead Investigator</span>
                    <span class="meta-value">{{ investigator }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Acquisition Time</span>
                    <span class="meta-value">{{ generation_time }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Target Type</span>
                    <span class="meta-value">Android Device</span>
                </div>
            </div>
        </header>

        <!-- Summary Badges -->
        <div class="summary-grid">
            <div class="summary-card">
                <div class="summary-count">{{ app_count }}</div>
                <div class="summary-label">Installed Apps</div>
            </div>
            <div class="summary-card">
                <div class="summary-count">{{ call_log_count }}</div>
                <div class="summary-label">Call Logs</div>
            </div>
            <div class="summary-card">
                <div class="summary-count">{{ sms_count }}</div>
                <div class="summary-label">SMS Records</div>
            </div>
            <div class="summary-card">
                <div class="summary-count">{{ browser_count }}</div>
                <div class="summary-label">Web History</div>
            </div>
            <div class="summary-card">
                <div class="summary-count">{{ whatsapp_count }}</div>
                <div class="summary-label">WhatsApp Files</div>
            </div>
            <div class="summary-card">
                <div class="summary-count">{{ media_count }}</div>
                <div class="summary-label">Media Files</div>
            </div>
        </div>

        <!-- Layout Grid -->
        <div class="layout-grid">
            
            <!-- Device Info Card -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Target Device Information</div>
                </div>
                <div class="device-info-grid">
                    <div class="device-info-item">
                        <span class="device-info-label">Manufacturer</span>
                        <span class="device-info-val">{{ device.manufacturer }}</span>
                    </div>
                    <div class="device-info-item">
                        <span class="device-info-label">Model</span>
                        <span class="device-info-val">{{ device.model }}</span>
                    </div>
                    <div class="device-info-item">
                        <span class="device-info-label">Android OS Version</span>
                        <span class="device-info-val">{{ device.android_version }} (SDK {{ device.sdk_version }})</span>
                    </div>
                    <div class="device-info-item">
                        <span class="device-info-label">Hardware Serial</span>
                        <span class="device-info-val">{{ device.serial }}</span>
                    </div>
                    <div class="device-info-item">
                        <span class="device-info-label">Brand</span>
                        <span class="device-info-val">{{ device.brand }}</span>
                    </div>
                    <div class="device-info-item">
                        <span class="device-info-label">Device Name</span>
                        <span class="device-info-val">{{ device.device_name }}</span>
                    </div>
                    <div class="device-info-item" style="grid-column: 1 / -1;">
                        <span class="device-info-label">Device Local Time</span>
                        <span class="device-info-val">{{ device.device_time }}</span>
                    </div>
                </div>
            </div>

            <!-- Tabbed Evidence Contents Card -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Extracted Evidence Explorer</div>
                </div>
                
                <div class="tabs-header">
                    <button class="tab-btn active" onclick="switchTab(event, 'tab-apps')">Installed Apps ({{ app_count }})</button>
                    <button class="tab-btn" onclick="switchTab(event, 'tab-calls')">Call Logs ({{ call_log_count }})</button>
                    <button class="tab-btn" onclick="switchTab(event, 'tab-sms')">SMS ({{ sms_count }})</button>
                    <button class="tab-btn" onclick="switchTab(event, 'tab-web')">Web History ({{ browser_count }})</button>
                    <button class="tab-btn" onclick="switchTab(event, 'tab-whatsapp')">WhatsApp ({{ whatsapp_count }})</button>
                    <button class="tab-btn" onclick="switchTab(event, 'tab-media')">Media ({{ media_count }})</button>
                </div>

                <!-- Apps Tab -->
                <div id="tab-apps" class="tab-content active">
                    {% if apps %}
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Package Name</th>
                                    <th>Version</th>
                                    <th>APK Path</th>
                                    <th>First Installed</th>
                                    <th>Last Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for app in apps %}
                                <tr>
                                    <td class="mono" style="color: var(--accent-blue);">{{ app.package }}</td>
                                    <td>{{ app.versionName }}</td>
                                    <td class="mono" style="font-size: 0.8rem;">{{ app.apk_path }}</td>
                                    <td>{{ app.firstInstallTime }}</td>
                                    <td>{{ app.lastUpdateTime }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No app records available.</p>
                    {% endif %}
                </div>

                <!-- Call Logs Tab -->
                <div id="tab-calls" class="tab-content">
                    {% if call_logs %}
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Phone Number</th>
                                    <th>Date/Time</th>
                                    <th>Duration (Sec)</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for call in call_logs %}
                                <tr>
                                    <td class="mono" style="color: var(--accent-teal);">{{ call.number }}</td>
                                    <td>{{ call.date | format_ts }}</td>
                                    <td>{{ call.duration }}</td>
                                    <td>
                                        {% if call.type == 1 %}Incoming
                                        {% elif call.type == 2 %}Outgoing
                                        {% elif call.type == 3 %}Missed
                                        {% else %}Unknown ({{ call.type }})
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No call log entries extracted (requires root access).</p>
                    {% endif %}
                </div>

                <!-- SMS Tab -->
                <div id="tab-sms" class="tab-content">
                    {% if sms_logs %}
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Address</th>
                                    <th>Date/Time</th>
                                    <th>Body</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for msg in sms_logs %}
                                <tr>
                                    <td class="mono">{{ msg.address }}</td>
                                    <td>{{ msg.date | format_ts }}</td>
                                    <td style="max-width: 400px; word-break: break-all;">{{ msg.body }}</td>
                                    <td>{{ 'Received' if msg.type == 1 else 'Sent' }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No SMS messages extracted (requires root access).</p>
                    {% endif %}
                </div>

                <!-- Web Tab -->
                <div id="tab-web" class="tab-content">
                    {% if browser_logs %}
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>URL</th>
                                    <th>Title</th>
                                    <th>Visits</th>
                                    <th>Last Visited</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for url in browser_logs %}
                                <tr>
                                    <td class="mono" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <a href="{{ url.url }}" target="_blank" style="color: var(--accent-blue); text-decoration: none;">{{ url.url }}</a>
                                    </td>
                                    <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{ url.title }}</td>
                                    <td>{{ url.visit_count }}</td>
                                    <td>{{ url.last_visit_time | format_ts }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No browser history logs extracted (requires root access).</p>
                    {% endif %}
                </div>

                <!-- WhatsApp Tab -->
                <div id="tab-whatsapp" class="tab-content">
                    {% if whatsapp_files %}
                    <p style="margin-bottom: 15px; color: var(--accent-teal);">Successfully extracted WhatsApp databases:</p>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Extracted File Name</th>
                                    <th>Storage Location</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for w_file in whatsapp_files %}
                                <tr>
                                    <td class="mono" style="font-weight: 600;">{{ w_file }}</td>
                                    <td class="mono">artefacts/whatsapp/{{ w_file }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No WhatsApp database files extracted (requires root access or WhatsApp not installed).</p>
                    {% endif %}
                </div>

                <!-- Media Tab -->
                <div id="tab-media" class="tab-content">
                    {% if media %}
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>On-Device Path</th>
                                    <th>Size (Bytes)</th>
                                    <th>Last Modified</th>
                                    <th>On-Device SHA-256</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in media %}
                                <tr>
                                    <td class="mono" style="font-size: 0.8rem;">{{ item.path }}</td>
                                    <td class="mono">{{ item.size }}</td>
                                    <td>{{ item.modified | format_ts }}</td>
                                    <td class="hash-val">{{ item.sha256 }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p style="color: var(--text-secondary);">No media metadata extracted.</p>
                    {% endif %}
                </div>
            </div>

            <!-- Hash Integrity Card -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Chain of Custody & File Integrity Manifest</div>
                </div>
                <p style="color: var(--text-secondary); margin-bottom: 20px;">
                    Below are the SHA-256 cryptographic signatures calculated for all exported evidence files immediately following acquisition.
                </p>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Relative Path</th>
                                <th>SHA-256 Cryptographic Hash Signature</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for file_path, hash_val in manifest.items() %}
                            <tr>
                                <td class="mono" style="font-weight: 600;">{{ file_path }}</td>
                                <td class="hash-val">{{ hash_val }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Signatures Card -->
            <div class="card">
                <div class="card-title">Acquisition Authentication</div>
                <p style="color: var(--text-secondary); margin-top: 10px;">
                    This acquisition report and associated files have been forensically preserved and hashed. Any subsequent modifications will break the integrity check against the signatures recorded above.
                </p>
                <div class="sign-grid">
                    <div>
                        <div class="sign-line"></div>
                        <div class="sign-title">Investigator Signature</div>
                    </div>
                    <div>
                        <div class="sign-line"></div>
                        <div class="sign-title">Date & Time</div>
                    </div>
                    <div>
                        <div class="sign-line"></div>
                        <div class="sign-title">Witness Signature (If Applicable)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer>
            <div class="footer-logo">Android Forensic Acquisition Tool</div>
            <div>Generated by Antigravity IDE Agentic Forensic Suite</div>
        </footer>
    </div>

    <script>
        function switchTab(evt, tabId) {
            var i, tabcontent, tablinks;
            tabcontent = document.getElementsByClassName("tab-content");
            for (i = 0; i < tabcontent.length; i++) {
                tabcontent[i].classList.remove("active");
            }
            tablinks = document.getElementsByClassName("tab-btn");
            for (i = 0; i < tablinks.length; i++) {
                tablinks[i].classList.remove("active");
            }
            document.getElementById(tabId).classList.add("active");
            evt.currentTarget.classList.add("active");
        }
    </script>
</body>
</html>